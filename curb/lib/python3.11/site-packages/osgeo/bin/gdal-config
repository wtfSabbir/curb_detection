#!/bin/sh
CONFIG_LIBS="-L/usr/local/lib64 -lgdal"
CONFIG_DEP_LIBS="-L/usr/local/lib -liconv -L/usr/local/lib64 -lssl -lcrypto -llzma -llz4 -larmadillo -ldeflate -ltiff -lavif -lheif -lLerc -lzstd -pthread -ljpeg -lpoppler -lpng -lgif -lnetcdf -lblosc -lcfitsio -lgta -lwebp -lhdf -lmfhdf -lxdr -lkea -lhdf5_cpp -lhdf5 -ldl -lmpi -lopenjp2 -lOpenEXR -lOpenEXRUtil -lImath -lIex -ljxl -ljxl_threads -lltidsdk -lgeotiff -lfyba -lfygm -lfyut -lOpenDrive -lpcre2-8 -lspatialite -lrasterlite2 -lsqlite3 -lxerces-c -lmysqlclient -lpq -lfreexl -lexpat -lxml2 -lgeos_c -lcurl -lproj -ljson-c -lz -lpthread -lstdc++ -lm"
CONFIG_PREFIX="/usr/local"
CONFIG_CFLAGS="-I/usr/local/include"
CONFIG_DATA="/usr/local/share/gdal"
CONFIG_VERSION="3.12.2"
CONFIG_GNM_ENABLED=yes
CONFIG_FORMATS="JPEG raw GTIFF MEM vrt Derived GTI LIBERTIFF HFA NITF GXF AAIGrid CEOS SAR_CEOS DTED JDEM Envisat L1B RS2 ILWIS RMF Leveller SRTMHGT IDRISI GSG ERS PALSARJaxa DIMAP GFF COSAR PDS ADRG COASP TSX Terragen MSGN TIL northwood SAGA XYZ AVIF HEIF ESRIC HF2 KMLSUPEROVERLAY CTG ZMap NGSGEOID IRIS MAP CALS SAFE SENTINEL2 PRF MRF WMTS GRIB BMP TGA STACTA SNAP_TIFF BSB AIGrid USGSDEM AirSAR PCIDSK SIGDEM MSG RIK STACIT PDF RCM GDALG PNG GIF WCS HTTP netCDF Zarr DAAS EEDA FITS HDF5 PLMOSAIC WMS OGCAPI GTA WEBP HDF4 MBTiles PostGISRaster KEA JP2OpenJPEG EXR PCRaster JPEGXL MiraMon MrSID GeoJSON TAB Shape KML VRT AVC GML CSV DGN GMT S57 GeoRSS DXF PGDump GPSBabel EDIGEO SXF OpenFileGDB WAsP Selafin JML VDV FlatGeobuf MapML ADBC MiraMon AIVector JSONFG GPX GMLAS CSW NAS PLSCENES SOSI WFS OAPIF NGW Elastic XODR Idrisi PDS SQLite GeoPackage OSM VFK MVT PMTiles AmigoCloud Carto ILI MySQL PG XLSX XLS CAD GTFS ODS LVBAG"
CONFIG_PLUGINDIR="/usr/local/lib64/gdalplugins"
usage()

{
	cat <<EOF
Usage: gdal-config [OPTIONS]
Options:
	[--prefix[=DIR]]
	[--libs]
	[--dep-libs]
	[--cflags]
	[--datadir]
	[--version]
	[--ogr-enabled]
	[--gnm-enabled]
	[--formats]
	[--plugindir]
EOF
	exit $1
}

if test $# -eq 0; then
	usage 1 1>&2
fi

case $1 in
  --libs)
    echo $CONFIG_LIBS
    ;;

  --dep-libs)
    echo $CONFIG_DEP_LIBS
    ;;

  --cflags)
    echo $CONFIG_CFLAGS
    ;;

  --datadir)
    echo $CONFIG_DATA
    ;;

  --prefix)
    echo $CONFIG_PREFIX
    ;;

  --version)
    echo $CONFIG_VERSION
    ;;

  --ogr-enabled)
    echo yes
    ;;

  --gnm-enabled)
    echo $CONFIG_GNM_ENABLED
    ;;

  --formats)
    echo $CONFIG_FORMATS
    ;;

  --plugindir)
    echo $CONFIG_PLUGINDIR
    ;;

  *)
    usage 1 1>&2
    ;;

esac
